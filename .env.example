# Required: OpenAI API key for the AI spec-editing endpoint (/api/motif/spec)
OPENAI_API_KEY=

# Optional: Override the model used by Motif's AI endpoint.
# Default: gpt-4o-mini
# To swap to Anthropic: install @ai-sdk/anthropic and update getModel() in src/core/ai/spec-edit.ts
# To use an AI Gateway: set "provider/model" string (e.g. "anthropic/claude-3-5-haiku")
# MOTIF_MODEL=gpt-4o-mini
